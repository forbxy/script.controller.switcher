<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
    <!-- 适用全局的按键映射 -->
    <global>
        <keyboard>
            <!-- c键或menu键: 长按打开设置页面 -->
            <c mod="longpress">ActivateWindow(Settings)</c>
            <menu mod="longpress">ActivateWindow(Settings)</menu>
            <!-- 快进键长按: 播放下一集 -->
            <fastforward mod="longpress">PlayerControl(Next)</fastforward>
            <!-- 快退键长按: 强制播放上一集 -->
            <rewind mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</rewind>
            <!-- 电影键短按: 打开电源库 -->
            <j>activatewindow(videos,movietitles)</j>
        </keyboard>
    </global>
    <!-- 全屏播放视频时的特定按键映射 -->
    <FullscreenVideo>
        <keyboard>
            <!-- 长按home，打开播放器进程信息 -->
            <home mod="longpress">playerprocessinfo</home>
            <browser_home mod="longpress">playerprocessinfo</browser_home>
        </keyboard>
    </FullscreenVideo>
    <!-- 将对应的操作（除上下方向键）也覆盖给 OSD 菜单，防止弹出菜单时按键失效 -->
    <VideoOSD>
        <keyboard>
            <!-- 长按home，打开播放器进程信息 -->
            <home mod="longpress">playerprocessinfo</home>
            <browser_home mod="longpress">playerprocessinfo</browser_home>
        </keyboard>
    </VideoOSD>
</keymap>