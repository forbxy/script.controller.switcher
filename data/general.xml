<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
    <!-- 适用全局的按键映射 -->
    <global>
        <keyboard>
            <!-- home键(标准键盘): 返回主页 -->
            <home>ActivateWindow(Home)</home>
            <!-- a键: 打开音乐页面 -->
            <a>ActivateWindow(Music)</a>
            <!-- f7键: 打开设置页面 -->
            <f7>ActivateWindow(Settings)</f7>
            <!-- f12键: 打开插件页面 -->
            <f12>ActivateWindow(1100)</f12>
            <!-- f5键: T9筛选界面 -->
            <f5>RunScript(plugin.video.filteredmovies, 0, ?mode=launch_t9)</f5>
            <!-- 浏览器搜索键: T9筛选界面 -->
            <browser_search>RunScript(plugin.video.filteredmovies, 0, ?mode=launch_t9)</browser_search>
            <!-- f8键: 更新视频库 -->
            <f8>updatelibrary(video)</f8>
            <!-- 收藏键：打开收藏页面 -->
            <favorites>activatewindow(favouritesbrowser)</favorites>
            <!-- F6键: 切换循环模式（仅播放音乐有效） -->
            <f6>PlayerControl(Repeat)</f6>
            <!-- 上一曲键: 强制播列表中的上一个项目 -->
            <prev_track>RunScript(plugin.video.filteredmovies, ?mode=force_prev)</prev_track>
        </keyboard>
    </global>
    <!-- 全屏播放视频时的特定按键映射 -->
    <FullscreenVideo>
        <keyboard>
            <!-- F4短按: 记录片头/片尾 -->
            <f4>RunScript(plugin.video.filteredmovies, ?mode=record_skip_point)</f4>
            <!-- F4长按: 删除记录好的片头/片尾 -->
            <f4 mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=delete_skip_point)</f4>
            <!-- i键: 打开播放器进程信息 -->
            <i>playerprocessinfo</i>
            <!-- l键(小写L): 全屏播放时，按上方向键调出字幕设置页面 -->
            <l>RunScript(plugin.video.filteredmovies, ?mode=select_subtitle)</l>
            <!-- f10键: 全屏播放时，按下方向键调出音轨选择页面 -->
            <f10>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</f10>
            <!-- PG+键: 下一章节，PG-键: 上一章节 -->
            <pageup>ChapterOrBigStepForward</pageup>
            <pagedown>ChapterOrBigStepBack</pagedown>
            <!-- 菜单键打开播放列表 -->
            <c>Playlist</c>
            <menu>Playlist</menu>
        </keyboard>
    </FullscreenVideo>
    <!-- 将对应的操作也覆盖给 OSD 菜单，防止弹出菜单时按键失效 -->
    <VideoOSD>
        <keyboard>
            <!-- F4短按: 记录片头/片尾 -->
            <f4>RunScript(plugin.video.filteredmovies, ?mode=record_skip_point)</f4>
            <!-- F4长按: 删除记录好的片头/片尾 -->
            <f4 mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=delete_skip_point)</f4>
            <!-- 上一曲键: 强制播放上一集(就算播放列表里没有也可以) -->
            <prev_track>RunScript(plugin.video.filteredmovies, ?mode=force_prev)</prev_track>
            <!-- i键: 打开播放器进程信息 -->
            <i>playerprocessinfo</i>
            <!-- l键(小写L): 全屏播放时，按上方向键调出字幕设置页面 -->
            <l>RunScript(plugin.video.filteredmovies, ?mode=select_subtitle)</l>
            <!-- f10键: 全屏播放时，按下方向键调出音轨选择页面 -->
            <f10>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</f10>
            <!-- PG+键: 下一章节，PG-键: 上一章节 -->
            <pageup>ChapterOrBigStepForward</pageup>
            <pagedown>ChapterOrBigStepBack</pagedown>
            <!-- 菜单键打开播放列表 -->
            <c>Playlist</c>
            <menu>Playlist</menu>
        </keyboard>
    </VideoOSD>
    <Window1100>
        <keyboard>
            <f12>Back</f12>
        </keyboard>
    </Window1100>
    <!-- 筛选页面的backspace键映射为删除 -->
    <!-- 动态加载的页面按先后顺序从13000开始，假设前三个里一定包含了筛选页 -->
    <Window13000>
        <keyboard>
            <backspace>Delete</backspace>
            <f5>Back</f5>
            <browser_search>Back</browser_search>
        </keyboard>
    </Window13000>
    <Window13001>
        <keyboard>
            <backspace>Delete</backspace>
            <f5>Back</f5>
            <browser_search>Back</browser_search>
        </keyboard>
    </Window13001>
    <Window13002>
        <keyboard>
            <backspace>Delete</backspace>
            <f5>Back</f5>
            <browser_search>Back</browser_search>
        </keyboard>
    </Window13002>
    <Music>
        <keyboard>
            <!-- f8键: 更新音乐库 -->
            <f8>updatelibrary(music)</f8>
        </keyboard>
    </Music>
</keymap>