<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
    
    <!-- 全屏播放视频时的特定按键映射 -->
    <FullscreenVideo>
        <keyboard>
            <!-- 上键: 全屏播放时，按上方向键调出字幕设置页面 -->
            <up>RunScript(plugin.video.filteredmovies, ?mode=select_subtitle)</up>
            <!-- 下键: 全屏播放时，按下方向键调出音轨选择页面 -->
            <down>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</down>
            <!-- PG+长按: 播放下一集  -->
            <pageup mod="longpress">PlayerControl(Next)</pageup>
            <!-- PG-长按: 强制播放上一集 -->
            <pagedown mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pagedown>
            <!-- 长按home，打开播放器进程信息 -->
            <home mod="longpress">playerprocessinfo</home>
            <browser_home mod="longpress">playerprocessinfo</browser_home>
        </keyboard>
    </FullscreenVideo>
    <!-- 将对应的操作（除上下方向键）也覆盖给 OSD 菜单，防止弹出菜单时按键失效 -->
    <VideoOSD>
        <keyboard>
            <down>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</down>
            <!-- PG+长按: 播放下一集  -->
            <pageup mod="longpress">PlayerControl(Next)</pageup>
            <!-- PG-长按: 强制播放上一集 -->
            <pagedown mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pagedown>
            <!-- 长按home，打开播放器进程信息 -->
            <home mod="longpress">playerprocessinfo</home>
            <browser_home mod="longpress">playerprocessinfo</browser_home>
        </keyboard>
    </VideoOSD>
    <!-- 筛选页面字幕键映射为 . ,信息键映射为Del -->
    <Window13000>
        <keyboard>
            <l>.</l>
            <i>Delete</i>
        </keyboard>
    </Window13000>
    <Window13001>
        <keyboard>
            <l>.</l>
            <i>Delete</i>
        </keyboard>
    </Window13001>
    <Window13002>
        <keyboard>
            <l>.</l>
            <i>Delete</i>
        </keyboard>
    </Window13002>
</keymap>