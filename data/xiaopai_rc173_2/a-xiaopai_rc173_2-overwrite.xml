<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
    <!-- 适用全局的按键映射 -->
    <global>
        <keyboard>
            <!-- c键或menu键: 长按打开设置页面 -->
            <c mod="longpress">ActivateWindow(Settings)</c>
            <menu mod="longpress">ActivateWindow(Settings)</menu>
            <!-- PG+长按: 播放下一集 -->
            <pagedown mod="longpress">PlayerControl(Next)</pagedown>
            <!-- PG-长按: 强制播放上一个 -->
            <pageup mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pageup>
        </keyboard>
    </global>
    <!-- 全屏播放视频时的特定按键映射 -->
    <FullscreenVideo>
        <keyboard>
            <!-- 上键: 全屏播放时，按上方向键调出字幕设置页面 -->
            <up>RunScript(plugin.video.filteredmovies, ?mode=select_subtitle)</up>
            <!-- 下键: 全屏播放时，按下方向键调出音轨选择页面 -->
            <down>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</down>
            <!-- c键或menu键: 长按打开设置页面 -->
            <c mod="longpress">ActivateWindow(Settings)</c>
            <menu mod="longpress">ActivateWindow(Settings)</menu>
            <!-- PG+长按: 播放下一集 -->
            <pagedown mod="longpress">PlayerControl(Next)</pagedown>
            <!-- PG-长按: 强制播放上一个 -->
            <pageup mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pageup>
        </keyboard>
    </FullscreenVideo>
    <!-- 将对应的操作（除上下方向键）也覆盖给 OSD 菜单，防止弹出菜单时按键失效 -->
    <VideoOSD>
        <keyboard>
            <!-- c键或menu键: 长按打开设置页面 -->
            <c mod="longpress">ActivateWindow(Settings)</c>
            <menu mod="longpress">ActivateWindow(Settings)</menu>
            <!-- PG+长按: 播放下一集 -->
            <pagedown mod="longpress">PlayerControl(Next)</pagedown>
            <!-- PG-长按: 强制播放上一个 -->
            <pageup mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pageup>
        </keyboard>
    </VideoOSD>
</keymap>