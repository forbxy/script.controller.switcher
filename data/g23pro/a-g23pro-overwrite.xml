<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
    <global>
        <keyboard>
            <f5 mod="meta">RunScript(plugin.video.filteredmovies, 0, ?mode=launch_t9)</f5>
        </keyboard>
    </global>
    
    <!-- 全屏播放视频时的特定按键映射 -->
    <FullscreenVideo>
        <keyboard>
            <!-- space键: 打开播放器进程信息 -->
            <space>playerprocessinfo</space>
            <!-- 上键: 全屏播放时，按上方向键调出字幕设置页面 -->
            <up>RunScript(plugin.video.filteredmovies, ?mode=select_subtitle)</up>
            <!-- 下键: 全屏播放时，按下方向键调出音轨选择页面 -->
            <down>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</down>
            <!-- PG+长按: 标记片头/片尾时间点  -->
            <pageup mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=record_skip_point)</pageup>
            <!-- PG-长按: 删除片头/片尾时间点标记 -->
            <pagedown mod="longpress">RunScript(plugin.video.filteredmovies,?mode=delete_skip_point)</pagedown>
        </keyboard>
    </FullscreenVideo>
    <!-- 将对应的操作（除上下方向键）也覆盖给 OSD 菜单，防止弹出菜单时按键失效 -->
    <VideoOSD>
        <keyboard>
            <!-- space键: 打开播放器进程信息 -->
            <space>playerprocessinfo</space>
            <!-- PG+长按: 标记片头/片尾时间点  -->
            <pageup mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=record_skip_point)</pageup>
            <!-- PG-长按: 删除片头/片尾时间点标记 -->
            <pagedown mod="longpress">RunScript(plugin.video.filteredmovies,?mode=delete_skip_point)</pagedown>
        </keyboard>
    </VideoOSD>
</keymap>