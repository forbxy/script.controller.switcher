<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
    
    <!-- 全屏播放视频时的特定按键映射 -->
    <FullscreenVideo>
        <keyboard>
            <!-- f1键(遥控上的红色): 全屏播放时，按下方向键调出音轨选择页面 -->
            <f1>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</f1>
            <!-- PG+长按: 播放下一集  -->
            <pageup mod="longpress">PlayerControl(Next)</pageup>
            <!-- PG-长按: 强制播放上一集 -->
            <pagedown mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pagedown>
        </keyboard>
    </FullscreenVideo>
    <!-- 将对应的操作（除上下方向键）也覆盖给 OSD 菜单，防止弹出菜单时按键失效 -->
    <VideoOSD>
        <keyboard>
            <!-- f1键(遥控上的红色): 全屏播放时，按下方向键调出音轨选择页面 -->
            <f1>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</f1>
            <!-- PG+长按: 播放下一集  -->
            <pageup mod="longpress">PlayerControl(Next)</pageup>
            <!-- PG-长按: 强制播放上一集 -->
            <pagedown mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=force_prev)</pagedown>
        </keyboard>
    </VideoOSD>
    <!-- 筛选页面字幕键映射为 . ,信息键映射为Del -->
    <Window13000>
        <keyboard>
            <l>.</l>
            <i>Delete</i>
        </keyboard>
    </Window13000>
    <Window13001>
        <keyboard>
            <l>.</l>
            <i>Delete</i>
        </keyboard>
    </Window13001>
    <Window13002>
        <keyboard>
            <l>.</l>
            <i>Delete</i>
        </keyboard>
    </Window13002>
</keymap>