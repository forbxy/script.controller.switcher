<?xml version="1.0" encoding="UTF-8"?>
<!-- generated by remotes.switcher on {TIME} -->
<keymap>
  <!-- 适用全局的按键映射 -->
  <global>
    <keyboard>
      <menu mod="longpress">RunScript(plugin.video.filteredmovies, 0, ?mode=launch_t9)</menu>
    </keyboard>
  </global>
  <!-- 全屏播放视频时的特定按键映射 -->
  <FullscreenVideo>
    <keyboard>
      <!-- 上键: 全屏播放时，按上方向键调出字幕设置页面 -->
      <up>RunScript(plugin.video.filteredmovies, ?mode=select_subtitle)</up>
      <!-- 下键: 全屏播放时，按下方向键调出音轨选择页面 -->
      <down>RunScript(plugin.video.filteredmovies, ?mode=select_audio)</down>
      <!-- 上键长按: 记录片头/片尾  -->
      <up mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=record_skip_point)</up>
      <!-- 下键长按: 删除记录好的片头/片尾 -->
      <down mod="longpress">RunScript(plugin.video.filteredmovies, ?mode=delete_skip_point)</down>
      <!-- 长按home，打开播放器进程信息 -->
      <home mod="longpress">playerprocessinfo</home>
      <browser_home mod="longpress">playerprocessinfo</browser_home>
      <!-- c键或menu键: 打开电视剧的本地媒体库页面 -->
      <c>RunScript(plugin.video.filteredmovies, ?mode=open_playing_tvshow)</c>
      <menu>RunScript(plugin.video.filteredmovies, ?mode=open_playing_tvshow)</menu>
    </keyboard>
  </FullscreenVideo>
</keymap>
